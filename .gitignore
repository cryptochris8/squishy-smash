# Codemagic local cache
.cm-cache/

# Card-pack source archives + scratch space. The 48-card collection
# is shipped via the compressed WebPs under `assets/cards/`; the source
# zips and extracted PNGs are preserved locally as backups but kept
# out of git so a repo clone doesn't pull ~130 MB of binaries that
# duplicate already-tracked content.
docs/Cards/_extracted/
docs/Cards/*.zip

# Book build artifacts (generated print PDFs + Python venv)
book/build/out/
book/build/.venv/
book/build/__pycache__/

# Screenshot pipeline build cache
screenshots/build/__pycache__/

# SECRETS — never commit
*.p8
*.p12
*.mobileprovision
*.keystore.json
*.pem
*.key
cert_key
cert_key.pub
.env
.env.local

# Marketing video outputs — regeneratable from tools/build_trailer_video.py.
# Trailers can run 15–22 MB each; treat them as build artifacts, not assets.
# Leading slash is intentional — matches ONLY the root-level marketing/ dir,
# not assets/audio/marketing/ which legitimately holds tracked VO MP3s.
/marketing/

# Book cover mockups — regeneratable from book/build/_render_title_mockup.py.
# These are design exploration renders, not source-of-truth.
book/mockups/

# Raw screen recordings — over GitHub's 100 MB push limit. Keep locally
# as the master input to the trailer pipeline; gitignore so they don't
# block pushes. Re-record into the same path when needed.
assets/images/ScreenRecording*.MP4
branding/ScreenRecording*.MP4
